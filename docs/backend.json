
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive user profile with gamification, credit, and career growth data.",
      "type": "object",
      "properties": {
        "majorship": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "credits": { "type": "integer", "default": 20 },
        "xp": { "type": "integer", "default": 0 },
        "level": { "type": "integer", "default": 1 },
        "isPro": { "type": "boolean", "default": false },
        "squadId": { "type": "string" },
        "dailyAdCount": { "type": "integer", "default": 0 },
        "lastAdXpTimestamp": { "type": "number" },
        "lastQuickFireTimestamp": { "type": "number" },
        "dailyAiUsage": { "type": "integer", "default": 0 },
        "dailyQuestionsAnswered": { "type": "integer", "default": 0 },
        "dailyTestsFinished": { "type": "integer", "default": 0 },
        "dailyCreditEarned": { "type": "integer", "default": 0 },
        "streakCount": { "type": "integer", "default": 0 },
        "lastActiveDate": { "type": "number" },
        "lastTaskReset": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralCount": { "type": "integer", "default": 0 },
        "referralCreditsEarned": { "type": "integer", "default": 0 },
        "referralTier": { "type": "string", "enum": ["Bronze", "Silver", "Gold", "Platinum"], "default": "Bronze" },
        "unlockedTracks": { "type": "array", "items": { "type": "string" } },
        "locationRegion": { "type": "string", "description": "The administrative region detected from phone." },
        "locationCity": { "type": "string", "description": "The city detected from phone." }
      }
    },
    "StudySquad": {
      "title": "Study Squad",
      "description": "A guild of teachers studying together for collective rewards.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "inviteCode": { "type": "string" },
        "creatorId": { "type": "string" },
        "memberCount": { "type": "integer", "default": 1 },
        "totalXp": { "type": "integer", "default": 0 },
        "level": { "type": "integer", "default": 1 },
        "createdAt": { "type": "number" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean", "default": true }
      },
      "required": ["id", "name", "inviteCode", "creatorId"]
    },
    "Friendship": {
      "title": "Peer Link",
      "description": "A denormalized connection between two teachers to save Spark plan reads.",
      "type": "object",
      "properties": {
        "userIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "number" },
        "initiatorId": { "type": "string" },
        "userNames": { "type": "object", "description": "Map of UID to display name" },
        "userPhotos": { "type": "object", "description": "Map of UID to photo URL" },
        "lastUpdated": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User specific profile settings and gamification stats."
    },
    "/squads/{squadId}": {
      "schema": "StudySquad",
      "description": "Guild data for collaborative studying."
    },
    "/friendships/{friendshipId}": {
      "schema": "Friendship",
      "description": "Peer-to-peer connection management."
    },
    "/friendships/{friendshipId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Conversation logs for a specific peer link."
    }
  }
}
